---
import Layout from '../layouts/Layout.astro';
import WholesalePortal from '../components/WholesalePortal';
import "../styles/global.css";
---

<Layout title="Wholesale Portal" description="Wholesale ordering portal for authorized Scoops & Smiles partners.">

  <!-- Page Hero -->
  <section class="relative h-60 flex items-end overflow-hidden bg-strawberry">
    <div class="absolute inset-0 bg-sprinkle-pattern opacity-30"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-10 w-full">
      <p class="font-script text-white/80 text-xl mb-1">Partners Only</p>
      <h1 class="font-display text-5xl font-bold text-white">Wholesale Portal</h1>
    </div>
    <svg class="absolute bottom-0 w-full" viewBox="0 0 1200 40" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
      <path d="M0,40 L0,20 C300,0 600,40 900,20 C1050,10 1150,30 1200,20 L1200,40 Z" fill="#fff8e8"/>
    </svg>
  </section>

  <!-- Intro Header -->
  <section class="py-4 bg-cream">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-display text-3xl sm:text-4xl font-bold text-chocolate mb-4">
        Looking to expand your ice cream selection for your store?
      </h2>
      <p class="font-body text-chocolate/80 text-lg leading-relaxed mb-4">
        The Big Dipper Ice Cream Parlour is here to help by providing premium wholesale ice cream delivered directly to you.
      </p>
      <p class="font-body text-chocolate/80 text-base mb-4">
        Wholesale items include gallons, UFO’s, and pies.
      </p>
      <p class="font-body text-chocolate font-semibold text-lg">
        Call <span class="text-strawberry"><a href="callto:+12037583200">203.758.3200</a></span> for more information
      </p>
    </div>
  </section>

  <!-- Portal -->
  <section class="py-4 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <WholesalePortal client:load />
  </section>

</Layout>