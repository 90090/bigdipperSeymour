  <!-- ═══════════════════════════════════════════════
       TEAM / PHOTO GALLERY
  ══════════════════════════════════════════════════ -->
  <section class="bg-bdteal py-16 text-center">
    <div class="max-w-3xl mx-auto px-4">
      <p class="font-script text-white/80 text-2xl mb-2">Come say hello</p>
      <h2 class="font-display text-3xl font-bold text-white mb-4">We'd love to meet you</h2>
      <p class="font-body text-white/90 leading-relaxed mb-8">
        Whether you're a first-timer or a 40-year regular, every guest gets the same warm welcome and the same care in every scoop. Stop in and see for yourself.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/order" class="inline-flex items-center gap-2 bg-white text-bdteal font-display font-bold px-8 py-3 rounded-full shadow-lg hover:-translate-y-0.5 transition-all">
          Order Online
        </a>
        <a href="/contact" class="inline-flex items-center gap-2 bg-white/20 text-white border-2 border-white/40 font-display font-bold px-8 py-3 rounded-full hover:bg-white/30 transition-all">
          Contact Us
        </a>
      </div>
    </div>
  </section>

</Layout>
