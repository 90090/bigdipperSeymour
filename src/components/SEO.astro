---
interface Props {
  title: string;
  description: string;
  image?: string;
  canonicalURL?: string;
  type?: 'website' | 'FoodEstablishment' | 'LocalBusiness';
  noindex?: boolean;
}

const {
  title,
  description,
  image = '/og-image.jpg',
  canonicalURL = Astro.url.href,
  type = 'website',
  noindex = false,
} = Astro.props;

const siteName = 'Big Dipper Seymour Ice Cream Parlour';
const fullTitle = `${title} | ${siteName}`;
const absoluteImage = Astro.site
  ? new URL(image, Astro.site).href
  : image;


// Local Business structured data — helps Google show your address,
// hours, and phone directly in search results
const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'IceCreamShop',
  name: 'Big Dipper Seymour Ice Cream Parlour',
  description: 'Handcrafted homestyle ice cream made fresh daily in small batches. Over 50 flavors, cakes, pies, and UFOs. Family-owned since 1986.',
  url: 'https://bigdipperseymour.com',
  telephone: '+1-203-999-0972',           
  priceRange: '$',
  servesCuisine: 'Ice Cream',
  address: {
    '@type': 'PostalAddress',
    streetAddress: '114 South Main St.',
    addressLocality: 'Seymour',
    addressRegion: 'CT',
    postalCode: '06483',                 
    addressCountry: 'US',
  },
  openingHoursSpecification: [
    { '@type': 'OpeningHoursSpecification', dayOfWeek: ['Monday','Tuesday','Wednesday','Thursday','Friday'], opens: '15:30', closes: '21:00' },
    { '@type': 'OpeningHoursSpecification', dayOfWeek: ['Saturday'], opens: '12:00', closes: '21:00' },
    { '@type': 'OpeningHoursSpecification', dayOfWeek: ['Sunday'], opens: '12:00', closes: '21:00' },
  ],
  sameAs: [
    'https://www.facebook.com/bigdippericecreamofseymour/',
    'https://www.instagram.com/bigdipperct',
  ],
  hasMenu: 'https://bigdipperseymour.com/order',
  award: [
    'Best Ice Cream — Waterbury Observer (20 consecutive years)',
    'National Ice Cream and Yogurt Retailers Association Award Winner',
  ],
};
---

<!-- ── Primary ─────────────────────────────────────────── -->
<title>{fullTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalURL} />
<link rel="sitemap" href="/sitemap-index.xml" />
{noindex && <meta name="robots" content="noindex, nofollow" />}

<!-- ── Open Graph (Facebook, iMessage previews, etc.) ──── -->
<meta property="og:type"        content={type} />
<meta property="og:url"         content={canonicalURL} />
<meta property="og:title"       content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:image"       content={absoluteImage} />
<meta property="og:image:width"  content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt"   content="Big Dipper Ice Cream Parlour — Seymour, CT" />
<meta property="og:site_name"   content={siteName} />
<meta property="og:locale"      content="en_US" />

<!-- ── Twitter / X Card ───────────────────────────────── -->
<meta name="twitter:card"        content="summary_large_image" />
<meta name="twitter:title"       content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image"       content={absoluteImage} />
<!-- <meta name="twitter:site" content="@bigdipperice" /> -->

<!-- ── Local Business Structured Data (JSON-LD) ──────── -->
<script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />