---
import '../styles/global.css';
import SEO from '../components/SEO.astro';
 
interface Props {
  title: string;
  description?: string;
  image?: string;
  noindex?: boolean;
}

const {
  title,
  description = 'Family-owned ice cream parlour in Seymour, CT. Over 50 homestyle flavors made fresh daily, plus cakes, pies, and UFOs. Voted Best Ice Cream for 20 years.',
  image,
  noindex = false,
} = Astro.props;
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/order', label: 'Order Online' },
  { href: 'https://www.bigdipper.com/wholesale', label: 'Wholesale' },
  { href: '/contact', label: 'Contact' },
];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🍦</text></svg>" />
  <SEO
    title={title}
    description={description}
    image={image}
    noindex={noindex}
    canonicalURL={Astro.url.href}
  />
</head>

<body class="bg-cream-50 font-body text-chocolate antialiased">

  <!-- Navigation -->
  <header class="sticky top-0 left-0 right-0 z-50 bg-cream border-b-2 border-cream-200 shadow-sm">
    <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between py-3">

        <!-- Logo -->
        <a href="/" class="flex items-center gap-3 group">
          <img
            src="/Logo-removebg.png"
            alt="Ice Cream Cone"
            class="w-20 h-20 transition-transform duration-300"
          >
        </img>
        </a>

        <!-- Desktop Nav -->
        <ul class="hidden md:flex items-center gap-7">
          {navLinks.map(link => (
            <li>
              <a
                href={link.href}
                class={`nav-link font-body text-sm font-bold uppercase tracking-widest transition-colors duration-200 pb-1 ${
                  currentPath === link.href
                    ? 'text-bdteal active'
                    : 'text-chocolate hover:text-bdteal'
                }`}
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>

        <!-- Mobile Menu Button -->
        <button id="mobile-menu-btn" class="md:hidden p-2 text-chocolate hover:text-bdteal focus:outline-none" aria-label="Toggle menu">
          <svg id="menu-open-icon" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
          <svg id="menu-close-icon" class="hidden" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>

      <!-- Mobile Menu -->
      <div id="mobile-menu" class="hidden md:hidden pb-4 border-t border-cream-200 pt-3">
        <ul class="flex flex-col gap-1">
          {navLinks.map(link => (
            <li>
              <a
                href={link.href}
                class={`block px-4 py-2 rounded-xl font-bold text-sm uppercase tracking-widest transition-colors ${
                  currentPath === link.href
                    ? 'bg-bdteal/10 text-bdteal'
                    : 'text-chocolate hover:text-bdteal hover:bg-cream-100'
                }`}
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </nav>
  </header>

  <!-- Main Content -->
  <main>
    <slot />
  </main>

  <!-- Footer -->
  <footer class="bg-chocolate text-cream-100 pt-16 pb-8">
    <!-- Scallop top -->
    <div class="w-full overflow-hidden -mt-1 mb-0" style="line-height:0">
      <svg viewBox="0 0 1200 40" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none" class="w-full h-10 -mt-10 block">
        <path d="M0,40 C50,40 50,0 100,0 C150,0 150,40 200,40 C250,40 250,0 300,0 C350,0 350,40 400,40 C450,40 450,0 500,0 C550,0 550,40 600,40 C650,40 650,0 700,0 C750,0 750,40 800,40 C850,40 850,0 900,0 C950,0 950,40 1000,40 C1050,40 1050,0 1100,0 C1150,0 1150,40 1200,40 Z" fill="#5c3317"/>
      </svg>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-12">

        <!-- Brand -->
        <div>
          <div class="font-script text-3xl text-cream mb-3">Big Dipper of Seymour</div>
          <p class="text-cream-200 text-sm leading-relaxed mb-5">
            Handcrafting happiness one scoop at a time since 1986. Made with love, and a whole lot of cream
          </p>
          <div class="flex gap-3">
            <a href="https://www.instagram.com/bigdipperct/" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="w-9 h-9 bg-white hover:bg-bdteal rounded-full flex items-center justify-center transition-colors">
              <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
            </a>
            <a href="https://www.facebook.com/bigdipperct/" target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="w-9 h-9 bg-white hover:bg-bdteal rounded-full flex items-center justify-center transition-colors">
              <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            </a>
          </div>
        </div>

        <!-- Quick Links -->
        <div>
          <h4 class="font-display font-semibold text-cream mb-4 text-lg">Quick Links</h4>
          <ul class="space-y-2">
            {navLinks.map(link => (
              <li>
                <a href={link.href} class="text-cream-200 hover:text-cream-300 text-sm transition-colors">
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Contact Info -->
        <div>
          <h4 class="font-display font-semibold text-cream mb-4 text-lg">Visit Us</h4>
          <address class="not-italic text-cream-200 text-sm space-y-2 leading-relaxed">
            <p>114 South Main St.<br/>Seymour, CT 06483</p>
            <p><a href="callto:+12039990972">(203) 999-0972</a></p>
            <p class="pt-1 font-semibold text-cream-300">Hours:</p>
            <p>Mon-Fri: 3:30pm - 9pm<br/>Sat-Sun: 12pm - 9pm</p>
          </address>
        </div>
      </div>

      <div class="border-t border-white/10 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4 text-cream-200/60 text-xs">
        <p>&copy; {new Date().getFullYear()} Big Dipper Ice Cream. All rights reserved.</p>
      </div>
    </div>
  </footer>

  <script>
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    const openIcon = document.getElementById('menu-open-icon');
    const closeIcon = document.getElementById('menu-close-icon');

    btn?.addEventListener('click', () => {
      const isHidden = menu?.classList.contains('hidden');
      menu?.classList.toggle('hidden', !isHidden);
      openIcon?.classList.toggle('hidden', isHidden);
      closeIcon?.classList.toggle('hidden', !isHidden);
    });
  </script>
</body>
</html>
